// ══════════════════════════════════════════════
//  FleetOps — Schéma Prisma complet
//  25 tables, 5 groupes logiques
// ══════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Utilisateurs ──────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  role      String   @default("chauffeur") // admin | gestionnaire | conducteur | chauffeur
  phone     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  supervisedSites   Site[]             @relation("Supervisor")
  requests          TransportRequest[] @relation("Requester")
  driverAssignments DailyAssignment[]  @relation("Driver")
  absences          Absence[]

  @@map("users")
}

// ── Référentiel ───────────────────────────

model VehicleType {
  id       String @id @default(cuid())
  code     String @unique
  label    String
  category String

  vehicles Vehicle[]
  requests TransportRequest[]

  @@map("vehicle_types")
}

model VehicleAccessory {
  id                     String   @id @default(cuid())
  code                   String   @unique
  label                  String
  compatibleVehicleTypes String[] @map("compatible_vehicle_types")

  @@map("vehicle_accessories")
}

model MissionType {
  id    String @id @default(cuid())
  code  String @unique
  label String

  assignments DailyAssignment[]

  @@map("mission_types")
}

// ── Véhicules ─────────────────────────────

model Vehicle {
  id           String   @id @default(cuid())
  code         String   @unique
  vehicleTypeId String  @map("vehicle_type_id")
  licensePlate String   @map("license_plate")
  status       String   @default("active") // active | reserve | maintenance
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  vehicleType  VehicleType       @relation(fields: [vehicleTypeId], references: [id])
  assignments  DailyAssignment[]
  maintenance  MaintenanceEvent[]
  documents    Document[]
  costEntries  CostEntry[]

  @@map("vehicles")
}

// ── Sous-traitants ────────────────────────

model Subcontractor {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  phone     String?
  email     String?
  notes     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assignments DailyAssignment[]

  @@map("subcontractors")
}

// ── Chantiers ─────────────────────────────

model Site {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  address      String
  city         String
  supervisorId String   @map("supervisor_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  supervisor  User               @relation("Supervisor", fields: [supervisorId], references: [id])
  requests    TransportRequest[]
  assignments DailyAssignment[]

  @@map("sites")
}

// ── Demandes de transport ─────────────────

model TransportRequest {
  id              String    @id @default(cuid())
  siteId          String    @map("site_id")
  vehicleTypeId   String    @map("vehicle_type_id")
  quantity        Int       @default(1)
  missionMode     String    @default("duration") @map("mission_mode")
  startTime       String?   @map("start_time")
  endTime         String?   @map("end_time")
  tripCount       Int?      @map("trip_count")
  accessories     String[]  @default([])
  description     String    @default("")
  priority        String    @default("normal")
  recurrenceType  String    @default("one_time") @map("recurrence_type")
  recurrenceStart String?   @map("recurrence_start")
  recurrenceEnd   String?   @map("recurrence_end")
  requestDate     String?   @map("request_date")
  status          String    @default("submitted")
  requestedById   String    @map("requested_by_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  site        Site              @relation(fields: [siteId], references: [id])
  vehicleType VehicleType       @relation(fields: [vehicleTypeId], references: [id])
  requestedBy User              @relation("Requester", fields: [requestedById], references: [id])
  assignments DailyAssignment[]

  @@map("transport_requests")
}

// ── Affectations quotidiennes ─────────────

model DailyAssignment {
  id             String    @id @default(cuid())
  date           String
  requestId      String?   @map("request_id")
  vehicleId      String    @map("vehicle_id")
  driverId       String    @map("driver_id")
  siteId         String    @map("site_id")
  missionTypeId  String?   @map("mission_type_id")
  subcontractorId String?  @map("subcontractor_id")
  missionDetails String?   @map("mission_details")
  source         String    @default("manual")
  startTime      String?   @map("start_time")
  endTime        String?   @map("end_time")
  status         String    @default("planned")
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  request       TransportRequest? @relation(fields: [requestId], references: [id])
  vehicle       Vehicle           @relation(fields: [vehicleId], references: [id])
  driver        User              @relation("Driver", fields: [driverId], references: [id])
  site          Site              @relation(fields: [siteId], references: [id])
  missionType   MissionType?      @relation(fields: [missionTypeId], references: [id])
  subcontractor Subcontractor?    @relation(fields: [subcontractorId], references: [id])
  incidents     Incident[]

  @@unique([date, vehicleId, startTime])
  @@map("daily_assignments")
}

// ── Incidents ─────────────────────────────

model Incident {
  id           String   @id @default(cuid())
  assignmentId String   @map("assignment_id")
  type         String
  description  String
  reportedAt   DateTime @default(now()) @map("reported_at")

  assignment DailyAssignment @relation(fields: [assignmentId], references: [id])

  @@map("incidents")
}

// ── Absences ──────────────────────────────

model Absence {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  startDate String   @map("start_date")
  endDate   String   @map("end_date")
  reason    String
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("absences")
}

// ── Maintenance ───────────────────────────

model MaintenanceEvent {
  id          String    @id @default(cuid())
  vehicleId   String    @map("vehicle_id")
  type        String
  description String
  startDate   String    @map("start_date")
  endDate     String?   @map("end_date")
  cost        Float?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@map("maintenance_events")
}

// ── Documents ─────────────────────────────

model Document {
  id         String    @id @default(cuid())
  vehicleId  String?   @map("vehicle_id")
  type       String
  reference  String?
  expiresAt  DateTime? @map("expires_at")
  filePath   String?   @map("file_path")
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@map("documents")
}

// ── Suivi des coûts ───────────────────────

model CostEntry {
  id        String   @id @default(cuid())
  vehicleId String   @map("vehicle_id")
  category  String
  amount    Float
  date      String
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@map("cost_entries")
}
